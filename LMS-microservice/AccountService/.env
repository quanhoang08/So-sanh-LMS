# ==========================================
# 1. SERVER CONFIGURATION
# ==========================================
# BẮT BUỘC KHÁC NHAU: Chạy ở cổng 3001 để không đụng chạm với module Academic (3000)
PORT=3001 
NODE_ENV=development

# ==========================================
# 2. DATABASE CONFIGURATION (PostgreSQL)
# ==========================================
# GIỐNG NHAU: Chung máy chủ PostgreSQL ở local
DB_HOST=account-db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=123456 # Đổi thành mật khẩu thực tế của bạn

# BẮT BUỘC KHÁC NHAU: Database riêng cho Account để đảm bảo tính độc lập dữ liệu
DB_NAME=accounts_db 

# ==========================================
# 3. SECURITY & JWT CONFIGURATION
# ==========================================
# GIỐNG NHAU TUYỆT ĐỐI: Phải giống hệt file .env bên UsersAssignment 
# Nếu lệch nhau, token tạo ra từ bên Account sẽ không thể dùng bên Academic được!
JWT_SECRET=super_secret_key_for_lms_2024
JWT_EXPIRES_IN=1d

# JWT Configuration
REFRESH_TOKEN_SECRET=refresh-secret-key
REFRESH_TOKEN_EXPIRES_IN=7d          # Refresh token expiry

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
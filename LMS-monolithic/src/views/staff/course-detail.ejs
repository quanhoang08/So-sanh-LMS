<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>LMS Staff — Chi tiết khóa học</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="layout">
  <%- include('../partials/staff-topbar') %>
  <div class="layout-body">
    <%- include('../partials/staff-sidebar', { activeMenu: 'classes' }) %>
    <main class="layout-main">
      <div class="max-content">

        <div class="page-header" style="display:flex;align-items:center;gap:12px;">
          <a href="/staff/courses" class="btn btn-ghost btn-sm" style="padding:6px 8px;">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </a>
          <div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
              <span style="font-size:.75rem;font-family:monospace;background:rgba(35,134,54,.15);color:#3fb950;border:1px solid rgba(35,134,54,.3);padding:3px 10px;border-radius:4px;">COURSE-<%= courseId %></span>
              <% if (course.status === 'published' || course.status === 'PUBLISHED') { %>
                <span class="badge badge-green">Đang hoạt động</span>
              <% } else if (course.status === 'pending' || course.status === 'PENDING') { %>
                <span class="badge badge-yellow">Chờ duyệt</span>
              <% } else if (course.status === 'closed' || course.status === 'CLOSED') { %>
                <span class="badge badge-red">Đã đóng</span>
              <% } else if (course.status === 'archived' || course.status === 'ARCHIVED') { %>
                <span class="badge badge-blue">Đã lưu trữ</span>
              <% } else { %>
                <span class="badge badge-blue">Bản nháp</span>
              <% } %>
            </div>
            <h1 style="font-size:1.5rem;font-weight:700;color:#fff;"><%= course.title || 'Khóa học' %></h1>
          </div>
        </div>

        <% if (updated) { %>
          <div class="card" style="padding:.75rem 1rem;border-color:rgba(35,134,54,.4);background:rgba(35,134,54,.12);margin-bottom:1rem;color:#9be9a8;">
            Đã lưu thay đổi khóa học thành công.
          </div>
        <% } %>
        <% if (notice) { %>
          <div class="card" style="padding:.75rem 1rem;border-color:rgba(35,134,54,.4);background:rgba(35,134,54,.12);margin-bottom:1rem;color:#9be9a8;">
            <%= notice %>
          </div>
        <% } %>
        <% if (error) { %>
          <div class="card" style="padding:.75rem 1rem;border-color:rgba(248,81,73,.45);background:rgba(248,81,73,.12);margin-bottom:1rem;color:#ffb4ad;">
            <%= error %>
          </div>
        <% } %>
        <% if (flowError) { %>
          <div class="card" style="padding:.75rem 1rem;border-color:rgba(248,81,73,.45);background:rgba(248,81,73,.12);margin-bottom:1rem;color:#ffb4ad;">
            <%= flowError %>
          </div>
        <% } %>

        <div class="grid-2" style="grid-template-columns:2fr 1fr;gap:2rem;align-items:start;">
          <!-- Left: Lessons -->
          <div>
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem;">
              <h2 style="font-size:1.1rem;font-weight:600;color:#fff;">Danh sách bài giảng</h2>
              <div style="display:flex;gap:8px;">
                <% if (canManageAssignments) { %>
                  <a class="btn btn-ghost btn-sm" href="/staff/courses/<%= courseId %>/assigned-lecturers">Phân công GV</a>
                <% } %>
                <button class="btn btn-green btn-sm" data-modal-open="modal-add-lesson">+ Thêm bài giảng</button>
              </div>
            </div>
            <div style="display:flex;flex-direction:column;gap:.75rem;">
              <% if (!course.lessons || course.lessons.length === 0) { %>
                <div class="card" style="padding:1rem;border-style:dashed;text-align:center;">
                  <p style="color:var(--text-muted);margin-bottom:.5rem;">Chưa có bài giảng nào được thêm.</p>
                  <p style="color:var(--text-muted);font-size:.85rem;margin-bottom:.85rem;">
                    Khu vực upload học liệu Supabase sẽ hiển thị bên dưới mỗi bài giảng sau khi bạn tạo bài giảng đầu tiên.
                  </p>
                  <button class="btn btn-green btn-sm" type="button" data-modal-open="modal-add-lesson">+ Tạo bài giảng đầu tiên</button>
                </div>
              <% } else { %>
                <% course.lessons.sort((a,b) => a.orderIndex - b.orderIndex).forEach(function(lesson){ %>
                <div class="card" style="padding:1rem;display:flex;flex-direction:column;gap:12px;">
                  <div style="display:flex; align-items:center; gap:12px;">
                    <div style="width:32px;height:32px;border-radius:6px;background:rgba(35,134,54,.15);border:1px solid rgba(35,134,54,.3);display:flex;align-items:center;justify-content:center;font-weight:700;color:#3fb950;font-size:.875rem;flex-shrink:0;"><%= lesson.orderIndex %></div>
                    <div style="flex:1;">
                      <div style="font-weight:500;color:#fff;font-size:1rem;"><%= lesson.title %></div>
                      <div style="font-size:.8rem;color:var(--text-muted);margin-top:2px;"><%= lesson.summary %></div>
                    </div>
                    <div style="display:flex;gap:6px;">
                      <button class="btn btn-ghost btn-sm">Sửa</button>
                      <form method="POST" action="/staff/courses/<%= courseId %>/lessons/<%= lesson.id %>/delete" style="display:inline;">
                        <button class="btn btn-red btn-sm" type="submit">Xóa</button>
                      </form>
                    </div>
                  </div>

                  <div style="padding-left:44px; font-size:.75rem; color:var(--text-muted);display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
                    <span>Upload học liệu (Supabase Storage)</span>
                    <% if (isSupabaseStorageReady) { %>
                      <span style="display:inline-flex;align-items:center;gap:6px;padding:2px 8px;border-radius:999px;border:1px solid rgba(35,134,54,.45);background:rgba(35,134,54,.15);color:#9be9a8;">
                        <span style="width:6px;height:6px;border-radius:50%;background:#3fb950;"></span>
                        Supabase: Ready
                      </span>
                    <% } else { %>
                      <span style="display:inline-flex;align-items:center;gap:6px;padding:2px 8px;border-radius:999px;border:1px solid rgba(248,81,73,.45);background:rgba(248,81,73,.12);color:#ffb4ad;">
                        <span style="width:6px;height:6px;border-radius:50%;background:#f85149;"></span>
                        Supabase: Not configured
                      </span>
                    <% } %>
                  </div>
                  <% if (!isSupabaseStorageReady) { %>
                    <div style="padding-left:44px; font-size:.72rem; color:#ffb4ad;">
                      Chưa cấu hình SUPABASE_URL hoặc SUPABASE_SERVICE_ROLE_KEY. Bạn vẫn có thể thêm học liệu bằng URL.
                    </div>
                  <% } %>
                  <form class="js-material-form" method="POST" enctype="multipart/form-data" action="/staff/lessons/<%= lesson.id %>/materials" style="display:flex;gap:8px;flex-wrap:wrap;padding-left:44px;">
                    <input class="form-input" name="fileName" placeholder="Tên học liệu" style="flex:1;min-width:180px;" required />
                    <input class="form-input js-material-file" type="file" name="file" style="flex:1;min-width:220px;" <%= !isSupabaseStorageReady ? 'disabled title="Supabase chưa được cấu hình"' : '' %> />
                    <input class="form-input js-material-url" name="fileUrl" placeholder="URL học liệu (nếu không upload file)" style="flex:1;min-width:220px;" />
                    <select class="form-input form-select" name="fileType" style="min-width:130px;">
                      <option value="document">document</option>
                      <option value="video">video</option>
                      <option value="audio">audio</option>
                      <option value="image">image</option>
                    </select>
                    <button type="submit" class="btn btn-ghost btn-sm">Thêm học liệu</button>
                  </form>

                  <!-- Materials -->
                  <% if (lesson.materials && lesson.materials.length > 0) { %>
                    <div style="padding-left:44px; display:flex; flex-direction:column; gap:6px;">
                      <% lesson.materials.forEach(mat => { %>
                        <div style="display:flex;align-items:center;justify-content:space-between;gap:8px;">
                          <a href="<%= mat.fileUrl %>" target="_blank" style="font-size:0.75rem; color:#58a6ff; text-decoration:none; display:flex; align-items:center; gap:6px;">
                            <span><%= mat.fileType === 'video' ? '🎬' : '📄' %></span>
                            <span><%= mat.fileName %></span>
                          </a>
                          <form method="POST" action="/staff/lessons/<%= lesson.id %>/materials/<%= mat.id %>/delete" style="margin:0;">
                            <button type="submit" class="btn btn-red btn-sm">Xóa</button>
                          </form>
                        </div>
                      <% }) %>
                    </div>
                  <% } %>
                </div>
                <% }) %>
              <% } %>
            </div>
          </div>

          <!-- Right: Enrolled students -->
          <div>
            <h2 style="font-size:1.1rem;font-weight:600;color:#fff;margin-bottom:1rem;">Chỉnh sửa khóa học</h2>
            <form class="card" method="POST" action="/staff/courses/<%= courseId %>/update" style="padding:1rem;margin-bottom:1rem;display:flex;flex-direction:column;gap:.75rem;">
              <div class="form-group" style="margin-bottom:0;">
                <label class="form-label">Tên khóa học</label>
                <input class="form-input" name="title" value="<%= course.title || '' %>" required />
              </div>

              <div class="form-group" style="margin-bottom:0;">
                <label class="form-label">Mô tả</label>
                <textarea class="form-input form-textarea" rows="4" name="description"><%= course.description || '' %></textarea>
              </div>

              <% if (canChangeStatus) { %>
                <div class="form-group" style="margin-bottom:0;">
                  <label class="form-label">Đổi trạng thái khóa học</label>
                  <select class="form-input form-select" name="status" <%= !statusOptions || statusOptions.length === 0 ? 'disabled' : '' %>>
                    <option value="">-- Giữ nguyên (<%= course.status %>) --</option>
                    <% (statusOptions || []).forEach(function(s){ %>
                      <option value="<%= s %>"><%= s %></option>
                    <% }) %>
                  </select>
                </div>
              <% } %>

              <div style="display:flex;gap:8px;">
                <button class="btn btn-green" type="submit">Lưu thay đổi</button>
                <a href="/staff/courses" class="btn btn-ghost">Hủy</a>
              </div>
            </form>

            <form method="POST" action="/staff/courses/<%= courseId %>/delete" onsubmit="return confirm('Bạn có chắc muốn xóa khóa học này?');" style="margin-bottom:1rem;">
              <button class="btn btn-red" type="submit">Xóa khóa học</button>
            </form>

            <h2 style="font-size:1.1rem;font-weight:600;color:#fff;margin-bottom:1rem;">Sinh viên ghi danh</h2>
            <div class="card" style="padding:.5rem;">
              <% if (!course.enrollments || course.enrollments.length === 0) { %>
                <p style="color:var(--text-muted); text-align:center; padding: 1.5rem; font-size:0.875rem;">Chưa có sinh viên đăng ký.</p>
              <% } else { %>
                <% course.enrollments.forEach(function(enroll){ %>
                <% const s = enroll.student; %>
                <div style="padding:.75rem;border-radius:6px;border-bottom:1px solid var(--border);">
                  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                    <div>
                      <div style="font-size:.875rem;font-weight:500;color:#fff;"><%= s.fullname %></div>
                      <div style="font-size:.7rem;color:var(--text-muted);font-family:monospace;"><%= s.email %></div>
                    </div>
                    <span style="font-size:.75rem;font-weight:700;color:var(--text-primary);"><%= enroll.progressPct %>%</span>
                  </div>
                  <% const progressColor = enroll.progressPct >= 80 ? '#3fb950' : (enroll.progressPct >= 50 ? '#1f6feb' : '#f85149'); %>
                  <div class="progress-bar progress-sm">
                    <div class="progress-bar-fill js-progress-fill" data-width="<%= enroll.progressPct %>" data-color="<%= progressColor %>"></div>
                  </div>
                </div>
                <% }) %>
              <% } %>
              <div style="padding:.75rem;text-align:center;">
                <button class="btn btn-ghost btn-sm" onclick="showToast('Tính năng đang phát triển!')">Xem tất cả sinh viên</button>
              </div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
  <footer class="layout-footer">
    <span>Copyright © 2026 TDTU. All rights reserved.</span>
    <span>Portal Giảng Viên v2.1</span>
  </footer>
</div>

<!-- Modal add lesson -->
<div id="modal-add-lesson" class="modal-overlay hidden">
  <div class="modal modal-lg">
    <div class="modal-header">
      <span class="modal-title">Thêm bài giảng mới</span>
      <button class="modal-close" data-modal-close="modal-add-lesson">&times;</button>
    </div>
    <form method="POST" action="/staff/courses/<%= courseId %>/lessons">
      <div class="modal-body">
        <div class="form-group">
          <label class="form-label">Tiêu đề bài giảng</label>
          <input type="text" class="form-input" name="title" placeholder="Nhập tiêu đề..." required>
        </div>
        <div class="form-group">
          <label class="form-label">Tóm tắt</label>
          <input type="text" class="form-input" name="summary" placeholder="Tóm tắt ngắn...">
        </div>
        <div class="form-group">
          <label class="form-label">Nội dung chi tiết</label>
          <textarea class="form-input form-textarea" rows="4" name="content" placeholder="Nội dung bài giảng..."></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-ghost" data-modal-close="modal-add-lesson">Hủy</button>
        <button type="submit" class="btn btn-green">Lưu bài giảng</button>
      </div>
    </form>
  </div>
</div>

<script src="/js/main.js"></script>
<script>
document.querySelectorAll('.js-progress-fill').forEach((el) => {
  const width = Number(el.getAttribute('data-width') || 0);
  const color = el.getAttribute('data-color') || '#1f6feb';
  el.style.width = width + '%';
  el.style.background = color;
});

document.querySelectorAll('.js-material-form').forEach((form) => {
  form.addEventListener('submit', (event) => {
    const fileInput = form.querySelector('.js-material-file');
    const urlInput = form.querySelector('.js-material-url');

    const hasFile = fileInput && fileInput.files && fileInput.files.length > 0;
    const hasUrl = urlInput && String(urlInput.value || '').trim().length > 0;

    if (!hasFile && !hasUrl) {
      event.preventDefault();
      if (typeof showToast === 'function') {
        showToast('Vui lòng chọn file hoặc nhập URL học liệu.', 'error');
      } else {
        alert('Vui lòng chọn file hoặc nhập URL học liệu.');
      }
    }
  });
});
</script>
</body>
</html>

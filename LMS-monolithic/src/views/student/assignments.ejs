<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>LMS — Bài tập của tôi</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .assignment-card { padding:1.25rem;display:flex;flex-direction:column;gap:.75rem; }
    @media(min-width:640px){ .assignment-card { flex-direction:row;align-items:center;justify-content:space-between; } }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/student-topbar') %>
  <div class="layout-body">
    <%- include('../partials/student-sidebar', { activeMenu: 'assignments' }) %>
    <main class="layout-main">
      <div class="max-content">

        <div class="page-header">
          <h1 class="page-title">
            <svg width="24" height="24" fill="none" stroke="#8b5cf6" stroke-width="2" viewBox="0 0 24 24"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>
            Tổng hợp Bài tập
          </h1>
        </div>

        <% 
        const allAssignments = (submissions || []).map((s) => ({
          id: s.id,
          course: s.quiz?.course?.id || '',
          courseName: s.quiz?.course?.title || 'Chưa có môn học',
          title: s.quiz?.title || `Bài nộp #${s.id}`,
          deadline: s.submittedAt,
          rawStatus: s.status,
          regradeRequested: !!s.regradeRequested,
          status: s.status === 'graded' || s.status === 'under_review' || s.status === 'submitted' ? 'submitted' : 'pending'
        }));
        const pending = allAssignments.filter(a => a.status === 'pending');
        const submitted = allAssignments.filter(a => a.status === 'submitted');
        const overdue = [];
        %>

        <!-- Tabs -->
        <div class="tabs" id="assign-tabs" data-tab-group="assignments">
          <button class="tab active-blue" data-tab="pending" data-active-class="active-blue" onclick="switchTab(this,'pending')">
            Cần làm (<%= pending.length %>)
          </button>
          <button class="tab" data-tab="submitted" data-active-class="active-green" onclick="switchTab(this,'submitted')">
            Đã nộp (<%= submitted.length %>)
          </button>
          <button class="tab" data-tab="overdue" data-active-class="active-red" onclick="switchTab(this,'overdue')">
            Quá hạn (<%= overdue.length %>)
          </button>
        </div>

        <!-- Tab panels -->

        <!-- Pending -->
        <div id="panel-pending">
          <% if (pending.length === 0) { %>
            <div class="empty-state card">
              <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>
              <p>Không có bài tập nào cần làm.</p>
            </div>
          <% } else { %>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              <% pending.forEach(function(item){ %>
              <div class="card assignment-card" style="transition:border-color .2s;" onmouseenter="this.style.borderColor='#8b949e'" onmouseleave="this.style.borderColor='var(--border)'">
                <div>
                  <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                    <span style="font-size:.7rem;font-family:monospace;background:var(--border);color:var(--text-primary);padding:2px 8px;border-radius:4px;"><%= item.course %></span>
                    <span style="font-size:.8rem;color:var(--text-muted);"><%= item.courseName %></span>
                  </div>
                  <h3 style="font-size:1rem;font-weight:500;color:#fff;margin-bottom:8px;"><%= item.title %></h3>
                  <p style="font-size:.8rem;color:var(--text-muted);display:flex;align-items:center;gap:4px;">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Hạn nộp: <%= item.deadline %>
                  </p>
                </div>
                <a href="/student/assignments/<%= item.id %>" class="btn btn-primary" style="white-space:nowrap;">Làm bài</a>
              </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <!-- Submitted -->
        <div id="panel-submitted" style="display:none;">
          <% if (submitted.length === 0) { %>
            <div class="empty-state card"><p>Chưa có bài nào được nộp.</p></div>
          <% } else { %>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              <% submitted.forEach(function(item){ %>
              <div class="card assignment-card">
                <div>
                  <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                    <span style="font-size:.7rem;font-family:monospace;background:var(--border);color:var(--text-primary);padding:2px 8px;border-radius:4px;"><%= item.course %></span>
                    <span style="font-size:.8rem;color:var(--text-muted);"><%= item.courseName %></span>
                  </div>
                  <h3 style="font-size:1rem;font-weight:500;color:#fff;margin-bottom:8px;"><%= item.title %></h3>
                  <p style="font-size:.8rem;color:var(--text-muted);">Hạn nộp: <%= item.deadline %></p>
                </div>
                <div style="display:flex;gap:8px;align-items:center;">
                  <% if (item.rawStatus === 'graded' && !item.regradeRequested) { %>
                    <button class="btn btn-ghost btn-sm" onclick="requestRegrade('<%= item.id %>')">Yêu cầu phúc khảo</button>
                  <% } else if (item.regradeRequested || item.rawStatus === 'under_review') { %>
                    <span class="badge badge-yellow" style="white-space:nowrap;">Đang phúc khảo</span>
                  <% } else { %>
                    <span class="badge badge-green" style="white-space:nowrap;">Đã hoàn thành</span>
                  <% } %>
                </div>
              </div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <!-- Overdue -->
        <div id="panel-overdue" style="display:none;">
          <% if (overdue.length === 0) { %>
            <div class="empty-state card"><p>Không có bài tập nào quá hạn.</p></div>
          <% } else { %>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              <% overdue.forEach(function(item){ %>
              <div class="card assignment-card">
                <div>
                  <div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
                    <span style="font-size:.7rem;font-family:monospace;background:var(--border);color:var(--text-primary);padding:2px 8px;border-radius:4px;"><%= item.course %></span>
                    <span style="font-size:.8rem;color:var(--text-muted);"><%= item.courseName %></span>
                  </div>
                  <h3 style="font-size:1rem;font-weight:500;color:#fff;margin-bottom:8px;"><%= item.title %></h3>
                  <p style="font-size:.8rem;color:#f85149;display:flex;align-items:center;gap:4px;">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    Đã quá hạn: <%= item.deadline %>
                  </p>
                </div>
                <button class="btn btn-ghost" disabled style="opacity:.5;white-space:nowrap;">Đã khóa</button>
              </div>
              <% }) %>
            </div>
          <% } %>
        </div>

      </div>
    </main>
  </div>
</div>
<script src="/js/main.js"></script>
<script>
function switchTab(btn, panel) {
  document.querySelectorAll('#assign-tabs .tab').forEach(t => t.classList.remove('active-blue','active-green','active-red'));
  const activeClass = btn.dataset.activeClass || 'active-blue';
  btn.classList.add(activeClass);
  ['pending','submitted','overdue'].forEach(p => {
    const el = document.getElementById('panel-' + p);
    if (el) el.style.display = p === panel ? 'block' : 'none';
  });
}

function requestRegrade(submissionId) {
  const note = prompt('Nhập lý do yêu cầu phúc khảo:');
  if (!note || !note.trim()) return;

  fetch('/api/v1/submissions/' + submissionId + '/regrade', {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ note: note.trim() }),
  })
    .then(async (res) => {
      const data = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(data.message || 'Không thể gửi yêu cầu phúc khảo.');
      showToast('Đã gửi yêu cầu phúc khảo!');
      window.location.reload();
    })
    .catch((err) => showToast(err.message || 'Yêu cầu thất bại.', 'error'));
}
</script>
</body>
</html>

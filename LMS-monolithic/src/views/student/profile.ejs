<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>LMS — Hồ sơ cá nhân</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .avatar-wrap { width:128px;height:128px;border-radius:50%;border:4px solid var(--border);overflow:hidden;background:var(--bg-base);margin:0 auto 1rem; }
    .avatar-wrap img { width:100%;height:100%;object-fit:cover; }
    .info-row { display:flex;align-items:flex-start;gap:8px;margin-bottom:1.25rem; }
    .info-row svg { width:16px;height:16px;flex-shrink:0;margin-top:2px;color:var(--text-muted); }
    .info-label { font-size:.8rem;color:var(--text-muted);display:flex;align-items:center;gap:6px;margin-bottom:4px; }
    .info-value { font-weight:500;color:#fff;font-size:.9rem; }
  </style>
</head>
<body>
<div class="layout">
  <%- include('../partials/student-topbar') %>
  <div class="layout-body">
    <%- include('../partials/student-sidebar', { activeMenu: 'profile' }) %>

    <main class="layout-main">
      <div class="max-content">

        <div class="page-header">
          <h1 class="page-title">
            <svg width="24" height="24" fill="none" stroke="#1f6feb" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Hồ sơ cá nhân
          </h1>
        </div>

        <!-- Warning banner -->
        <div class="alert alert-warn" style="justify-content:space-between;align-items:flex-start;">
          <p style="font-size:.875rem;">Vui lòng kiểm tra kỹ thông tin cá nhân. Nếu có sai sót, hãy liên hệ Phòng Đại học trước ngày 15/05/2026.</p>
          <button style="background:none;border:none;color:#eab308;cursor:pointer;font-size:1.2rem;padding:0 0 0 12px;" onclick="this.parentElement.remove()">×</button>
        </div>

        <% if (updated) { %>
          <div class="alert" style="background:rgba(35,134,54,.12);border:1px solid rgba(35,134,54,.35);color:#3fb950;">
            Cập nhật thông tin thành công.
          </div>
        <% } %>
        <% if (error) { %>
          <div class="alert alert-red" style="margin-top:10px;">
            <%= error %>
          </div>
        <% } %>

        <div class="grid-2" style="grid-template-columns:1fr 2fr;align-items:start;">
          <!-- Avatar card -->
          <div class="card" style="text-align:center;padding:2rem;">
            <div class="avatar-wrap">
              <img src="<%= user?.avatarUrl || 'https://github.com/identicons/default.png' %>" alt="Avatar" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 100 100\'%3E%3Crect width=\'100\' height=\'100\' fill=\'%2321262d\'/%3E%3Ctext x=\'50\' y=\'60\' font-size=\'40\' text-anchor=\'middle\' fill=\'%238b949e\'%3E👤%3C/text%3E%3C/svg%3E'">
            </div>
            <h2 style="font-size:1.25rem;font-weight:700;color:#fff;margin-bottom:6px;"><%= user?.fullname || 'Chưa có thông tin' %></h2>
            <p style="font-family:monospace;background:var(--bg-hover);color:var(--text-primary);padding:4px 12px;border-radius:9999px;font-size:.875rem;display:inline-block;margin-bottom:1rem;">
              MSSV: <%= user?.mssv || (user?.email ? user.email.split('@')[0] : 'N/A') %>
            </p>
            <div class="badge badge-green" style="display:inline-flex;gap:6px;">
              <span class="badge-dot dot-green"></span>
              <%
                const rawStatus = String(user?.status || '').toLowerCase();
                const readableStatus = rawStatus === 'active'
                  ? 'Đang học'
                  : rawStatus === 'inactive'
                    ? 'Tạm ngưng'
                    : rawStatus === 'banned'
                      ? 'Bị khóa'
                      : 'Không rõ';
              %>
              Trạng thái: <%= readableStatus %>
            </div>
          </div>

          <!-- Detail info card -->
          <div class="card">
            <div class="card-header">
              <h3 style="font-weight:600;color:var(--text-primary);">Thông tin chi tiết</h3>
            </div>
            <div class="card-body">
              <div class="grid-2" style="gap:1.25rem;">
                <div>
                  <div class="info-label">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                    Khoa chủ quản
                  </div>
                  <div class="info-value"><%= user?.khoa || 'Chưa cập nhật' %></div>
                </div>
                <div>
                  <div class="info-label">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                    Ngành học
                  </div>
                  <div class="info-value"><%= user?.nganh || 'Chưa cập nhật' %></div>
                </div>
                <div>
                  <div class="info-label">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    Email sinh viên
                  </div>
                  <div class="info-value"><%= user?.email || 'Chưa cập nhật' %></div>
                </div>
                <div>
                  <div class="info-label">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    Số điện thoại
                  </div>
                  <div class="info-value"><%= user?.phone || 'Chưa cập nhật' %></div>
                </div>
                <div style="grid-column:1/-1;">
                  <div class="info-label">
                    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    Địa chỉ liên hệ
                  </div>
                  <div class="info-value"><%= user?.diaChi || 'Chưa cập nhật' %></div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card" style="margin-top:1rem;">
          <div class="card-header">
            <h3 style="font-weight:600;color:var(--text-primary);">Cập nhật thông tin liên hệ</h3>
          </div>
          <div class="card-body">
            <form method="POST" action="/student/profile" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
              <div>
                <label class="info-label" for="phone">Số điện thoại</label>
                <input
                  id="phone"
                  name="phone"
                  type="text"
                  value="<%= user?.phone || '' %>"
                  placeholder="Nhập số điện thoại"
                  style="width:100%;background:var(--bg-base);border:1px solid var(--border);border-radius:8px;padding:.65rem .75rem;color:#fff;outline:none;"
                />
              </div>

              <div style="grid-column:1/-1;">
                <label class="info-label" for="diaChi">Địa chỉ liên hệ</label>
                <input
                  id="diaChi"
                  name="diaChi"
                  type="text"
                  value="<%= user?.diaChi || '' %>"
                  placeholder="Nhập địa chỉ liên hệ"
                  style="width:100%;background:var(--bg-base);border:1px solid var(--border);border-radius:8px;padding:.65rem .75rem;color:#fff;outline:none;"
                />
              </div>

              <div style="grid-column:1/-1;display:flex;justify-content:flex-end;">
                <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
              </div>
            </form>
          </div>
        </div>

      </div>
    </main>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>

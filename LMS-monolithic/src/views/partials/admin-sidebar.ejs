<%# Admin Sidebar partial — activeMenu variable controls highlight %>
<aside class="sidebar">
  <nav class="sidebar-nav">
    <ul>
      <li>
        <a href="/admin/dashboard" class="<%= activeMenu === 'dashboard' ? 'active-blue' : '' %>">
          <%- icon('dashboard', 'w-5 h-5') %> Dashboard
        </a>
      </li>
      <li>
        <a href="/admin/users" class="<%= activeMenu === 'users' ? 'active-blue' : '' %>">
          <%- icon('users', 'w-5 h-5') %> Quản lý User
        </a>
      </li>
      <li>
        <a href="/admin/categories" class="<%= activeMenu === 'categories' ? 'active-blue' : '' %>">
          <%- icon('book', 'w-5 h-5') %> Danh mục khóa học
        </a>
      </li>
      <li>
        <a href="/admin/department-heads" class="<%= activeMenu === 'department-heads' ? 'active-blue' : '' %>">
          <%- icon('shield', 'w-5 h-5') %> Trưởng bộ môn
        </a>
      </li>
      <li>
        <a href="/admin/settings" class="<%= activeMenu === 'settings' ? 'active-blue' : '' %>">
          <%- icon('settings', 'w-5 h-5') %> Cài đặt hệ thống
        </a>
      </li>
    </ul>
  </nav>
  <div class="sidebar-footer">
    <div style="padding:0 8px 12px;font-size:.75rem;color:#8b949e;">
      <div style="font-weight:600;color:#fff;">admin@lms.edu.vn</div>
      <div style="display:flex;align-items:center;gap:6px;margin-top:4px;">
        <span class="badge-dot dot-green"></span>
        <span style="text-transform:uppercase;letter-spacing:.05em;">ADMIN Mode</span>
      </div>
    </div>
    <button class="sidebar-logout" onclick="window.location.href='/api/v1/auth/logout'">
      <%- icon('logout', 'w-5 h-5') %> Đăng xuất
    </button>
  </div>
</aside>
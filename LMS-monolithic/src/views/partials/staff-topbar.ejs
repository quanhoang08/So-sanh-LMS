<%# Staff Topbar partial %>
<header class="topbar">
  <div class="topbar-logo">
    <img src="/images/logo.png" alt="LMS" onerror="this.style.display='none'">
    <div>
      <div class="topbar-title">LMS System</div>
      <div class="topbar-badge">Cổng Giảng Viên</div>
    </div>
  </div>
  <div class="topbar-right">
    <button class="topbar-semester">HK2 2526 <%- icon('chevron_down', 'w-4 h-4') %></button>
    <div class="topbar-divider"></div>
    <div style="display:flex;align-items:center;gap:10px;color:#8b949e;">
      <button class="topbar-icon-btn"><%- icon('message', 'w-5 h-5') %></button>
      <button class="topbar-icon-btn">
        <%- icon('bell', 'w-5 h-5') %>
        <span class="badge-count">2</span>
      </button>
    </div>
    <% 
      let initials = 'GV';
      if (typeof user !== 'undefined' && user?.fullname) {
        const parts = user.fullname.split(' ');
        initials = parts[parts.length - 1].charAt(0).toUpperCase();
      }
    %>
    <div class="avatar-circle" style="background:#7c3aed;cursor:pointer;" title="<%= typeof user !== 'undefined' && user?.fullname ? user.fullname : 'Giảng viên' %>"><%= initials %></div>
  </div>
</header>
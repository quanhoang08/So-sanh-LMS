{
  "id": null,
  "uid": "lms-benchmark",
  "title": "LMS Benchmark Overview",
  "tags": ["benchmark", "lms", "cadvisor"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU Usage % (Monolith vs Microservices)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=~\"monolith|monolith-db\"}[1m])) * 100",
          "legendFormat": "Monolith total CPU %"
        },
        {
          "refId": "B",
          "expr": "sum(rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=~\"api-gateway|account-service|course-service|academic-service|account-db|course-db|academic-db|rabbitmq\"}[1m])) * 100",
          "legendFormat": "Microservices total CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0 },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Memory Usage MiB (Monolith vs Microservices)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=~\"monolith|monolith-db\"}) / 1024 / 1024",
          "legendFormat": "Monolith total RAM MiB"
        },
        {
          "refId": "B",
          "expr": "sum(container_memory_working_set_bytes{container_label_com_docker_compose_service=~\"api-gateway|account-service|course-service|academic-service|account-db|course-db|academic-db|rabbitmq\"}) / 1024 / 1024",
          "legendFormat": "Microservices total RAM MiB"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decbytes", "min": 0 },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Network Receive MiB/s (Monolith vs Microservices)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=~\"monolith|monolith-db\"}[1m])) / 1024 / 1024",
          "legendFormat": "Monolith RX MiB/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(container_network_receive_bytes_total{container_label_com_docker_compose_service=~\"api-gateway|account-service|course-service|academic-service|account-db|course-db|academic-db|rabbitmq\"}[1m])) / 1024 / 1024",
          "legendFormat": "Microservices RX MiB/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "binBps", "min": 0 },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Network Transmit MiB/s (Monolith vs Microservices)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=~\"monolith|monolith-db\"}[1m])) / 1024 / 1024",
          "legendFormat": "Monolith TX MiB/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(container_network_transmit_bytes_total{container_label_com_docker_compose_service=~\"api-gateway|account-service|course-service|academic-service|account-db|course-db|academic-db|rabbitmq\"}[1m])) / 1024 / 1024",
          "legendFormat": "Microservices TX MiB/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "binBps", "min": 0 },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU by Service %",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service=~\"monolith|monolith-db|api-gateway|account-service|course-service|academic-service|account-db|course-db|academic-db|rabbitmq\"}[1m])) * 100",
          "legendFormat": "{{container_label_com_docker_compose_service}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0 },
        "overrides": []
      }
    }
  ],
  "templating": { "list": [] },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}

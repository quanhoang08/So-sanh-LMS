# ==========================================
# CẤU HÌNH SERVER
# ==========================================
PORT=3002
NODE_ENV=development

# ==========================================
# CẤU HÌNH DATABASE (PostgreSQL / MySQL)
# ==========================================
# Nếu chạy ngoài Docker: dùng localhost
# Nếu chạy trong Docker Compose: dùng tên container của database (VD: postgres-db hoặc mysql-db)
DB_HOST=course-db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=123456
DB_DATABASE=course_db

# Bật tính năng tự động đồng bộ schema (Chỉ nên để true ở môi trường dev)
# DB_SYNCHRONIZE=true

# ==========================================
# CẤU HÌNH RABBITMQ
# ==========================================
# Nếu chạy ngoài Docker: amqp://localhost:5672
# Nếu chạy trong Docker Compose: amqp://[tên-container-rabbitmq]:5672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_COURSE_QUEUE=course_queue

# ==========================================
# CẤU HÌNH BẢO MẬT (JWT)
# ==========================================
# Khóa bí mật này phải GIỐNG HỆT với khóa ở Auth Service / Academic Service
JWT_SECRET=super_secret_key_for_lms_2024



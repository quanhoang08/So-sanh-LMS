<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>LMS — Chi tiết khóa học</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="layout">
  <%- include('../partials/student-topbar') %>
  <div class="layout-body">
    <%- include('../partials/student-sidebar', { activeMenu: 'course' }) %>
    <main class="layout-main">
      <div class="max-content">

        <!-- Header -->
        <div class="page-header flex items-center gap-3" style="display:flex;align-items:center;gap:12px;">
          <a href="/student/courses" class="btn btn-ghost btn-sm" style="padding:6px 8px;">
            <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          </a>
          <div>
            <h1 style="font-size:1.5rem;font-weight:700;color:#fff;"><%= course.title %></h1>
            <p style="font-size:.875rem;color:var(--text-muted);">Mã môn: <%= course.id %> • Giảng viên: <%= course.createdBy?.fullname || 'N/A' %></p>
          </div>
        </div>

        <div class="grid-2" style="grid-template-columns:2fr 1fr;align-items:start;gap:2rem;">
          <!-- Assignments -->
          <div>
            <h2 style="font-size:1.125rem;font-weight:600;color:#fff;display:flex;align-items:center;gap:8px;margin-bottom:1rem;">
              <svg width="18" height="18" fill="none" stroke="#1f6feb" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Bài tập & Đánh giá (Quizzes)
            </h2>
            <div style="display:flex;flex-direction:column;gap:1rem;">
              <% if (!course.quizzes || course.quizzes.length === 0) { %>
                <p style="color:var(--text-muted);">Chưa có bài tập nào.</p>
              <% } else { %>
                <% course.quizzes.forEach(function(quiz){ %>
                <div class="card" style="padding:1.25rem;display:flex;flex-direction:column;gap:.75rem;">
                  <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">
                    <div>
                      <h3 style="font-size:1rem;font-weight:500;color:var(--text-primary);margin-bottom:4px;"><%= quiz.title %></h3>
                      <p style="font-size:.8rem;color:var(--text-muted);display:flex;align-items:center;gap:4px;">
                        <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                        Thời gian: <%= quiz.durationMin || '_' %> phút
                      </p>
                    </div>
                    <a href="/student/quizzes/<%= quiz.id %>" class="btn btn-primary btn-sm">Bắt đầu làm bài</a>
                  </div>
                </div>
                <% }) %>
              <% } %>
            </div>
          </div>

          <!-- Materials -->
          <div>
            <h2 style="font-size:1.125rem;font-weight:600;color:#fff;display:flex;align-items:center;gap:8px;margin-bottom:1rem;">
              <svg width="18" height="18" fill="none" stroke="#a5a0ff" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
              Tài liệu môn học
            </h2>
            <div class="card" style="padding:.5rem;">
              <% 
                // Flatten materials from all lessons
                const allMaterials = (course.lessons || []).flatMap(l => l.materials || []);
              %>
              <% if (allMaterials.length === 0) { %>
                <p style="color:var(--text-muted); padding:1rem; font-size:0.875rem;">Chưa có tài liệu.</p>
              <% } else { %>
                <% allMaterials.forEach(function(mat){ %>
                <div style="display:flex;align-items:center;justify-content:space-between;padding:.75rem;border-radius:6px;transition:background .15s;cursor:pointer;" onmouseenter="this.style.background='var(--bg-hover)'" onmouseleave="this.style.background='transparent'">
                  <div style="flex:1;overflow:hidden;padding-right:8px;">
                    <p style="font-size:.8rem;font-weight:500;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= mat.fileName %></p>
                    <p style="font-size:.7rem;color:var(--text-muted);"><%= mat.fileType.toUpperCase() %></p>
                  </div>
                  <a href="<%= mat.fileUrl %>" target="_blank" style="background:none;border:none;cursor:pointer;color:var(--text-muted);padding:6px;border-radius:4px;display:flex;align-items:center;" onmouseenter="this.style.background='var(--border)';this.style.color='#fff'" onmouseleave="this.style.background='none';this.style.color='var(--text-muted)'">
                    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                  </a>
                </div>
                <% }) %>
              <% } %>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>

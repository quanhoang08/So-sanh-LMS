<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
  <title>LMS Staff — Tổng quan</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="layout">
  <%- include('../partials/staff-topbar') %>
  <div class="layout-body">
    <%- include('../partials/staff-sidebar', { activeMenu: 'profile' }) %>
    <main class="layout-main">
      <div class="max-content">

        <div class="page-header">
          <h1 class="page-title" style="display:flex;align-items:center;gap:8px;">
            <svg width="22" height="22" fill="none" stroke="#238636" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Tổng quan Giảng dạy — HK2 2526
          </h1>
        </div>

        <div class="grid-3 mb-8">
          <div class="stat-card">
            <div class="stat-label">Lớp học đang phụ trách</div>
            <div class="stat-value text-white"><%= courses.length %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Bài tập cần chấm</div>
            <div class="stat-value text-orange"><%= pendingCount %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Tin nhắn chưa đọc</div>
            <div class="stat-value text-blue">0</div>
          </div>
        </div>

        <!-- Quick links -->
        <div class="grid-2">
          <div class="card">
            <div class="card-header"><h3 style="font-weight:600;color:#fff;">Lớp học đang quản lý</h3></div>
            <div class="card-body">
              <% if (courses && courses.length > 0) { %>
                <% courses.slice(0, 5).forEach(function(cls){ %>
                <div style="display:flex;align-items:center;gap:12px;padding:.75rem 0;border-bottom:1px solid var(--border);">
                  <div style="width:40px;height:40px;border-radius:8px;background:rgba(35,134,54,.15);border:1px solid rgba(35,134,54,.3);display:flex;align-items:center;justify-content:center;font-size:.65rem;font-weight:700;color:#3fb950;font-family:monospace;">ID:<%= cls.id %></div>
                  <div>
                    <div style="font-weight:500;color:#fff;font-size:.875rem;"><%= cls.title %></div>
                    <div style="font-size:.75rem;color:var(--text-muted);">Trạng thái: <%= cls.status %></div>
                  </div>
                </div>
                <% }) %>
              <% } else { %>
                <p style="color:var(--text-muted); padding:1rem 0;">Chưa có lớp học nào.</p>
              <% } %>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><h3 style="font-weight:600;color:#fff;">Bài cần chấm gần đây</h3></div>
            <div class="card-body">
              <% if (recentSubmissions && recentSubmissions.length > 0) { %>
                <% recentSubmissions.forEach(function(item){ %>
                <div style="display:flex;align-items:flex-start;justify-content:space-between;padding:.75rem 0;border-bottom:1px solid var(--border);">
                  <div>
                    <div style="font-weight:500;color:#fff;font-size:.875rem;"><%= item.student?.fullname || 'Ẩn danh' %></div>
                    <div style="font-size:.75rem;color:var(--text-muted);margin-top:2px;">Bài: <%= item.quiz?.title || 'N/A' %></div>
                    <div style="font-size:.7rem;color:var(--text-muted);">Nộp: <%= item.submittedAt ? new Date(item.submittedAt).toLocaleString('vi-VN') : 'N/A' %></div>
                  </div>
                  <% if (item.regradeRequested || item.status === 'under_review') { %>
                    <span class="badge badge-red" style="font-size:.65rem;">Phúc khảo</span>
                  <% } else if (item.status === 'submitted') { %>
                    <span class="badge badge-yellow">Chờ chấm</span>
                  <% } else { %>
                    <span class="badge badge-green">Đã chấm</span>
                  <% } %>
                </div>
                <% }) %>
              <% } else { %>
                <p style="color:var(--text-muted); padding:1rem 0;">Chưa có bài nộp nào mới.</p>
              <% } %>
              <div style="margin-top:1rem;">
                <a href="/staff/grading" class="btn btn-ghost btn-sm btn-block" style="justify-content:center;">Xem tất cả bài nộp</a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </main>
  </div>
  <footer class="layout-footer">
    <span>Copyright © 2026 TDTU. All rights reserved.</span>
    <span>Portal Giảng Viên v2.1</span>
  </footer>
</div>
<script src="/js/main.js"></script>
</body>
</html>

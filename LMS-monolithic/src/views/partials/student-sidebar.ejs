<%# Student Sidebar partial %>
<aside class="sidebar">
  <nav class="sidebar-nav">
    <ul>
      <li>
        <a href="/student/profile" class="<%= activeMenu === 'profile' ? 'active-blue' : '' %>">
          <%- icon('user', 'w-5 h-5') %> Hồ sơ cá nhân
        </a>
      </li>
      <li>
        <a href="/student/assignments" class="<%= activeMenu === 'assignments' ? 'active-blue' : '' %>">
          <%- icon('clipboard', 'w-5 h-5') %> Bài tập của tôi
        </a>
      </li>
      <li>
        <a href="/student/courses" class="<%= activeMenu === 'course' ? 'active-blue' : '' %>">
          <%- icon('book', 'w-5 h-5') %> Khóa học
        </a>
      </li>
      <li>
        <a href="/student/attendance" class="<%= activeMenu === 'attendance' ? 'active-blue' : '' %>">
          <%- icon('user_check', 'w-5 h-5') %> Điểm danh
        </a>
      </li>
    </ul>
  </nav>
  <div class="sidebar-footer">
    <button class="sidebar-logout" onclick="window.location.href='/api/v1/auth/logout'">
      <%- icon('logout', 'w-5 h-5') %> Đăng xuất
    </button>
  </div>
</aside>
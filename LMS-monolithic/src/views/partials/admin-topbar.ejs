<%# Admin Topbar partial %>
<header class="topbar">
  <div class="topbar-logo">
    <div style="width:32px;height:32px;background:#1f6feb;border-radius:6px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:11px;font-weight:700;">LMS</div>
    <div>
      <div style="font-size:1rem;font-weight:600;color:#fff;">Admin Center</div>
      <div style="font-size:0.65rem;color:#8b949e;text-transform:uppercase;letter-spacing:.05em;">Microservices System</div>
    </div>
  </div>
  <div class="topbar-right">
    <div class="topbar-divider"></div>
    <div style="display:flex;align-items:center;gap:12px;color:#8b949e;">
      <button class="topbar-icon-btn"><%- icon('bell', 'w-5 h-5') %></button>
    </div>
    <div class="avatar-circle" style="background:#1f6feb;cursor:pointer;" title="<%= typeof user !== 'undefined' && user?.email ? user.email : 'Administrator' %>">AD</div>
  </div>
</header>